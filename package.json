{
  "name": "aimetric",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:dashboard": "pnpm --filter @aimetric/dashboard dev",
    "start:collector-gateway": "pnpm --filter @aimetric/collector-gateway build && pnpm --filter @aimetric/collector-gateway start",
    "start:metric-platform": "pnpm --filter @aimetric/metric-platform build && pnpm --filter @aimetric/metric-platform start",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3",
    "zod": "^3.24.3"
  }
}
