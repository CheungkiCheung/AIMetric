DATABASE_URL=postgresql://aimetric:aimetric@127.0.0.1:5432/aimetric?sslmode=disable
METRIC_PLATFORM_URL=http://127.0.0.1:3001
AIMETRIC_COLLECTOR_TOKEN=replace-with-collector-token
METRIC_PLATFORM_ADMIN_TOKEN=replace-with-admin-token
METRIC_SNAPSHOT_RECALCULATION_INTERVAL_MS=60000
INGESTION_DELIVERY_MODE=sync
INGESTION_QUEUE_BACKEND=memory
INGESTION_QUEUE_DIR=/tmp/aimetric-ingestion-queue
